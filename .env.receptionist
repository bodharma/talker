# Receptionist-only config — just LiveKit credentials needed.
# LiveKit free tier (sign up with GitHub) includes STT, LLM, and TTS.
#
# Usage:
#   cp .env.receptionist .env
#   # Fill in your LiveKit credentials from https://cloud.livekit.io
#   uv run python -m talker.livekit_agent start

# LiveKit Cloud — get these from your project dashboard
LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# No database needed — visitor tracking is disabled without it
DATABASE_URL=

# Weather API (optional — falls back to mock London weather if not set)
# Free tier: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=

