# App
APP_SECRET_KEY=change-me-in-production
BASE_URL=http://localhost:8000
ALLOWED_HOSTS=*
DEBUG=true

# Auth — admin bootstrap (creates admin user on first startup)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Auth — OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Database
DATABASE_URL=postgresql+asyncpg://talker:talker@localhost:5432/talker
POSTGRES_PASSWORD=talker

# LLM — OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL_CONVERSATION=anthropic/claude-sonnet-4-20250514
OPENROUTER_MODEL_SCREENER=anthropic/claude-haiku-4-20250414
LLM_PROVIDER=openrouter

# LLM — Ollama (local fallback)
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# RAG / Embeddings
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=5

# Langfuse (observability + prompt management)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Voice — local
VOICE_PROVIDER=local
VOICE_LOCAL_STT_MODEL=base
VOICE_LOCAL_TTS_MODEL=en_US-amy-medium
VOICE_LOCAL_MODELS_DIR=models/voice

# Voice — cloud
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_VOICE_ID=

# Voice — LiveKit (for receptionist / real-time personas)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Weather API (used by receptionist persona)
OPENWEATHERMAP_API_KEY=
